# EditorConfig — https://editorconfig.org/
#
# Keeps whitespace, indentation, and newline conventions consistent
# across editors. Honoured natively by VS Code, JetBrains IDEs, Vim
# (with plugin), Sublime, and most others.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

[*.py]
indent_size = 4

[*.{yml,yaml,json,tf,tfvars,hcl}]
indent_size = 2

[*.md]
# Markdown intentionally preserves trailing whitespace (used for line breaks).
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
