# FinOps Automation Hub — Environment Variables
# Copy this file to .env and fill in values for your environment.
# These override any settings in hub_config.yaml.

# ── General ──
# FINOPS_AUDIT_DIR=audit_store
# FINOPS_POLICY_DIR=policies
# FINOPS_EVENT_STORE=sqlite
# FINOPS_EVENT_STORE_PATH=events.db

# ── Thresholds ──
# FINOPS_ANOMALY_MULTIPLIER=2.0

# ── Monitoring ──
# FINOPS_POLL_INTERVAL=900

# ── Tagging ──
# FINOPS_REQUIRED_TAGS=team,cost-centre,environment,owner

# ── Pricing Regions ──
# FINOPS_AWS_REGION=eu-west-2
# FINOPS_GCP_REGION=europe-west2

# ── Notifications ──
# FINOPS_SLACK_WEBHOOK=https://hooks.slack.com/services/T.../B.../...
# FINOPS_PAGERDUTY_KEY=your-routing-key
# FINOPS_WEBHOOK_URL=https://your-endpoint.example.com/finops-alerts

# ── Provider Scope ──
# FINOPS_AWS_REGIONS=eu-west-2,us-east-1
# FINOPS_GCP_PROJECTS=my-project-id
