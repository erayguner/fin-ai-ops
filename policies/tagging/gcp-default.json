{
  "policy_id": "tagging-gcp-default-2026",
  "name": "GCP 2026 Default Labelling Policy",
  "description": "Baseline labelling for every GCP resource (FinOps Foundation 2026 minimum set). GCP label keys use lowercase with underscores or hyphens per GCP naming constraints. Covers cost attribution, lifecycle, ownership, and compliance.",
  "provider": "gcp",
  "required_tags": [
    "team",
    "cost_centre",
    "environment",
    "owner",
    "application",
    "managed_by",
    "data_classification"
  ],
  "recommended_tags": [
    "business_unit",
    "project",
    "compliance_scope",
    "expiry_date"
  ],
  "resource_types": [],
  "exempt_resource_types": [
    "iam.serviceaccounts",
    "iam.roles",
    "dns.managed-zones-records",
    "billing.accounts",
    "monitoring.metric-descriptors",
    "logging.log-entries"
  ],
  "tag_value_patterns": {
    "cost_centre": "cc-[0-9]{4}",
    "environment": "prod|staging|dev|sandbox|shared",
    "data_classification": "public|internal|confidential|restricted",
    "managed_by": "terraform|deployment-manager|config-controller|pulumi|manual",
    "expiry_date": "[0-9]{4}-[0-9]{2}-[0-9]{2}|none"
  },
  "severity_when_missing": "warning",
  "enabled": true,
  "created_at": "2026-04-16T00:00:00+00:00",
  "updated_at": "2026-04-16T00:00:00+00:00"
}
